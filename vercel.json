{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "qwabi.co.za" }],
      "destination": "https://www.qwabi.co.za/:path*",
      "permanent": true
    },
    {
      "source": "/blog/xhosa-boy-names-meanings-origins",
      "destination": "/blog/xhosa-boy-names",
      "permanent": true
    },
    {
      "source": "/blog/xhosa-girl-names-meanings-origins",
      "destination": "/blog/xhosa-girl-names",
      "permanent": true
    },
    {
      "source": "/blog/claude-ai-building-apps-2026",
      "destination": "/blog/claude-ai-for-building-apps-2026",
      "permanent": true
    },
    {
      "source": "/blog/mastra-supabase-agents",
      "destination": "/blog/mastra-supabase-2026",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/social-post?slot=1",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/social-post?slot=2",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/social-post?slot=3",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/social-post?slot=4",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/social-post?slot=5",
      "schedule": "0 18 * * *"
    }
  ],
  "functions": {
    "api/cron/social-post.ts": {
      "maxDuration": 60
    }
  }
}
