# Copy to repo root as .env.local (gitignored):
#   cp scripts/social/env.example .env.local

# Instagram off by default until token is fixed
SOCIAL_INSTAGRAM_ENABLED=false

# --- Meta Graph API ---
GRAPH_API_VERSION=25.0

# --- Facebook Page (posting) ---
FACEBOOK_PAGE_ID=
# Long-lived page token (preferred name). Same as legacy FACEBOOK_DEVELOPER_APP_PAGE_ACCESS_TOKEN.
FACEBOOK_PAGE_ACCESS_TOKEN=

# Or resolve page token from user token + app-scoped user id:
APP_SCOPED_USER_ID=
FACEBOOK_USER_TOKEN=
FACEBOOK_USER_TOKEN_EXPIRES_IN_DAYS=

# App credentials (token exchange only)
FACEBOOK_DEVELOPER_APP_ID=
FACEBOOK_DEVELOPER_APP_SECRET=

# Legacy aliases (still supported)
FACEBOOK_DEVELOPER_APP_PAGE_ACCESS_TOKEN=
FACEBOOK_DEVELOPER_APP_TOKEN=

# --- Instagram ---
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# --- Stock images ---
PEXELS_API_KEY=
VECTEEZY_ACCOUNT_ID=
VECTEEZY_SECRET_KEY=
